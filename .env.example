# =============================================================================
# SIGA-LACEN — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores antes de iniciar.
# NUNCA versione o arquivo .env.
# =============================================================================

# Django
SECRET_KEY=troque-por-uma-chave-segura-de-50-caracteres
DEBUG=False
ALLOWED_HOSTS=siga.lacen.local,localhost,127.0.0.1

# CORS (origens que podem chamar a API)
CORS_ALLOWED_ORIGINS=https://siga.lacen.local

# Banco de dados PostgreSQL
DB_NAME=siga_lacen
DB_USER=siga_user
DB_PASSWORD=troque-por-uma-senha-forte
DB_HOST=db
DB_PORT=5432

# Django settings module (production | development)
DJANGO_SETTINGS_MODULE=config.settings.production
